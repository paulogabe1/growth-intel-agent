# Shared base .env. research_agent/ and content-transform-agent/ both
# load this first, then layer their own .env on top -- local values
# win, everything else inherits from here.

# Get a free key (no card required) at https://console.groq.com/keys
GROQ_API_KEY=your-key-here

# Optional. Defaults to groq/llama-3.3-70b-versatile if unset.
GROQ_MODEL=groq/llama-3.3-70b-versatile

# Optional -- without these, research_agent falls back to a local
# findings.json file. Free Supabase project at supabase.com; run
# research_agent/schema.sql once, then grab these from Project
# Settings > API Keys (secret key, not publishable -- backend-only).
SUPABASE_URL=your-project-url-here
SUPABASE_KEY=your-secret-key-here
