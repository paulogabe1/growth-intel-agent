# Shared base .env for the whole project. research_agent/ and (when
# used inside this repo) content-transform-agent/ both load these
# values first, then layer their own local .env on top. Anything
# defined in a subfolder's own .env overrides the value here;
# anything not redefined there just inherits from here.

# Get a free key (no card required) at https://console.groq.com/keys
GROQ_API_KEY=your-key-here

# Optional. Defaults to groq/llama-3.3-70b-versatile if unset.
GROQ_MODEL=groq/llama-3.3-70b-versatile

# Free Supabase project at https://supabase.com. Run
# research_agent/schema.sql in the SQL editor once, then get these
# from Project Settings, API Keys. Use the secret key, not
# publishable. These scripts are backend-only, never exposed to a
# browser or end user, so secret is probably the correct one.
SUPABASE_URL=your-project-url-here
SUPABASE_KEY=your-secret-key-here
